local function toggleSpeedBoost()
    if speedBoostConn then
        speedBoostConn:Disconnect()
        speedBoostConn = nil
    end
   
    if speedStealActive then
        speedBoostConn = RunService.RenderStepped:Connect(function()
            local char = player.Character
            if not char then return end
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not humanoid or not hrp then return end
            local moveDir = humanoid.MoveDirection
            if moveDir.Magnitude > 0 then
                hrp.AssemblyLinearVelocity =
                    (moveDir.Unit * 29) + Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
            end
        end)
    end
end
local function toggleInfJump()
    if not infJumpActive then return end
   
    local heartbeatConn
    local jumpConn
   
    heartbeatConn = RunService.Heartbeat:Connect(function()
        if not infJumpActive then
            if heartbeatConn then heartbeatConn:Disconnect() end
            return
        end
        local char = player.Character
        if not char then return end
       
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Velocity.Y < -clampFallSpeed then
            hrp.Velocity = Vector3.new(hrp.Velocity.X, -clampFallSpeed, hrp.Velocity.Z)
        end
    end)
   
    jumpConn = UserInputService.JumpRequest:Connect(function()
        if not infJumpActive then
            if jumpConn then jumpConn:Disconnect() end
            return
        end
        local char = player.Character
        if not char then return end
       
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Velocity = Vector3.new(hrp.Velocity.X, jumpForce, hrp.Velocity.Z)
        end
    end)
end

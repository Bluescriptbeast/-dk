-- Auto Bat Functions (orijinal)
local currentTarget = nil
local hb = nil
local lv, att, gyro = nil, nil, nil

local function getTarget()
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= player then return p end
    end
end

local function getBat()
    for _,v in ipairs(player.Backpack:GetChildren()) do
        if v:IsA("Tool") and string.find(v.Name:lower(),"bat") then return v end
    end
    local char = player.Character
    if char then
        for _,v in ipairs(char:GetChildren()) do
            if v:IsA("Tool") and string.find(v.Name:lower(),"bat") then return v end
        end
    end
end

local function startAutoBat()
    if hb then hb:Disconnect() end
    if lv then lv:Destroy() end
    if gyro then gyro:Destroy() end
    if att then att:Destroy() end
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    att = Instance.new("Attachment", hrp)
    lv = Instance.new("LinearVelocity")
    lv.Attachment0 = att
    lv.MaxForce = math.huge
    lv.Parent = hrp
    gyro = Instance.new("AlignOrientation")
    gyro.Attachment0 = att
    gyro.MaxTorque = math.huge
    gyro.Responsiveness = 120
    gyro.Parent = hrp
    currentTarget = getTarget()
    hb = RunService.Heartbeat:Connect(function()
        if not autoBatActive or not currentTarget then return end
        local tChar = currentTarget.Character
        local tHrp = tChar and tChar:FindFirstChild("HumanoidRootPart")
        if not tHrp then return end
        local front = tHrp.Position + tHrp.CFrame.LookVector * 2
        local dir = front - hrp.Position
        if dir.Magnitude > 1 then
            lv.VectorVelocity = dir.Unit * 50
        else
            lv.VectorVelocity = Vector3.zero
        end
        gyro.CFrame = CFrame.lookAt(hrp.Position, front)
        local bat = getBat()
        if bat then
            if bat.Parent ~= char then hum:EquipTool(bat) end
            bat:Activate()
        end
    end)
end

local function stopAutoBat()
    autoBatActive = false
    currentTarget = nil
    if hb then hb:Disconnect() hb = nil end
    if lv then lv:Destroy() lv = nil end
    if gyro then gyro:Destroy() gyro = nil end
    if att then att:Destroy() att = nil end
end

-- Toggle Functions (orijinal)
local function toggleSpeedBoost()
    if speedBoostConn then
        speedBoostConn:Disconnect()
        speedBoostConn = nil
    end
    if speedStealActive then
        speedBoostConn = RunService.RenderStepped:Connect(function()
            local char = player.Character
            if not char then return end
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not humanoid or not hrp then return end
            local moveDir = humanoid.MoveDirection
            if moveDir.Magnitude > 0 then
                hrp.AssemblyLinearVelocity = (moveDir.Unit * 29) + Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
            end
        end)
    end
end

local function toggleInfJump()
    if not infJumpActive then return end
    local heartbeatConn = RunService.Heartbeat:Connect(function()
        if not infJumpActive then heartbeatConn:Disconnect() return end
        local char = player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Velocity.Y < -80 then
            hrp.Velocity = Vector3.new(hrp.Velocity.X, -80, hrp.Velocity.Z)
        end
    end)
    UserInputService.JumpRequest:Connect(function()
        if not infJumpActive then return end
        local char = player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Velocity = Vector3.new(hrp.Velocity.X, 50, hrp.Velocity.Z)
        end
    end)
end

